// TODO nf-core: Specify any additional parameters here
// Or any resources requirements
params {
    modules_testdata_base_path = 'https://raw.githubusercontent.com/CDCgov/CAMPneu/test-datasets/modules/data/'
    pipelines_testdata_base_path = 'https://raw.githubusercontent.com/CDCgov/CAMPneu/test-datasets/refs/heads/campneu'
}

aws.client.anonymous = true // fixes S3 access issues on self-hosted runners
